    </div>

    <div class="footer__col">
      <h4>Quick Links</h4>
      <ul>
        <li><a href="/sunset-concert-series">Sunset Concert Series</a></li>
        <li><a href="/tiny-gallery">Tiny Gallery Concerts</a></li>
        <li><a href="/donate">Support Us</a></li>
        <li><a href="/contact">Contact</a></li>
