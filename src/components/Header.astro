---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const eventsSubpages = [
  { href: `${base}sunset-concert-series`, label: 'Sunset Concert Series' },
  { href: `${base}tiny-gallery`, label: 'Tiny Gallery Concerts' },
];

const isEventsActive = currentPath.includes('/sunset-concert-series')
  || currentPath.includes('/tiny-gallery');
---

<header class="site-header">
  <nav class="nav">
    <a href={base} class="nav__logo">
      <img src={`${base}images/logo.svg`} alt="Geneseo Jam Fund logo" width="48" height="48" />
      <div class="nav__logo-text">
        Geneseo Jam Fund
        <span>501(c)(3) Non-Profit</span>
      </div>
    </a>

    <button class="nav__mobile-toggle" aria-label="Toggle navigation" id="nav-toggle">
      &#9776;
    </button>

    <ul class="nav__links" id="nav-links">
      <li>
        <a href={base} class:list={[{ active: currentPath === base || currentPath === base.slice(0, -1) }]}>Home</a>
      </li>
      <li class="nav__dropdown">
        <button class:list={['nav__dropdown-trigger', { active: isEventsActive }]}>
          Events <span class="nav__caret">&#9662;</span>
        </button>
        <ul class="nav__dropdown-menu">
          {eventsSubpages.map(({ href, label }) => (
            <li>
              <a href={href} class:list={[{ active: currentPath.includes(href.replace(base, '/')) }]}>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </li>
      <li>
        <a href={`${base}photos`} class:list={[{ active: currentPath.includes('/photos') }]}>Photos</a>
      </li>
      <li>
        <a href={`${base}about`} class:list={[{ active: currentPath.includes('/about') }]}>About</a>
      </li>
      <li>
        <a href={`${base}donate`} class:list={[{ active: currentPath.includes('/donate') }]}>Donate</a>
      </li>
      <li>
        <a href={`${base}contact`} class:list={[{ active: currentPath.includes('/contact') }]}>Contact</a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const links = document.getElementById('nav-links');
  toggle?.addEventListener('click', () => links?.classList.toggle('open'));

  // Mobile: toggle dropdown submenu on click
  document.querySelectorAll('.nav__dropdown-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.parentElement?.classList.toggle('open');
    });
  });
</script>
