---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Geneseo Jam Fund is a 501(c)(3) non-profit promoting live music in Geneseo, NY through the Sunset Concert Series, Tiny Gallery Concerts, and community events.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} | Geneseo Jam Fund</title>
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}images/logo.svg`} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
