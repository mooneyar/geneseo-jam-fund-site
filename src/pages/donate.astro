---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Donate" description="Support the Geneseo Jam Fund with a tax-deductible donation. Your contribution keeps live music alive in Geneseo, NY.">
  <div class="page-header">
    <div class="container">
      <h1>Support the 2026 Sunset Concert Series</h1>
      <p>Your donation helps bring free live music to Geneseo this summer</p>
    </div>
  </div>

  <section class="section">
    <div class="container text-center">
      <div class="prose" style="margin-bottom: 2.5rem;">
        <p>
          Your tax-deductible donation directly supports free community concerts, fair
          musician pay, sound equipment, and the operations that make our events possible.
          Whether it's $25 or $1,000, every contribution makes a real difference.
        </p>
      </div>

      <h2>Donate Online</h2>
      <p style="color: var(--color-text-light); margin-bottom: 1.5rem;">
        Click any amount below to donate securely via Stripe.
      </p>

      <div class="donate-tiers">
        <p class="donate-tier-label">Jam Friend</p>
        <div class="donate-grid">
          <a href="https://buy.stripe.com/9B6aEY1ym1oyaCifdZgIo03" class="btn btn--primary" target="_blank" rel="noopener">$10</a>
          <a href="https://donate.stripe.com/9B628s7WK4AK11I7LxgIo01" class="btn btn--primary" target="_blank" rel="noopener">$25</a>
          <a href="https://buy.stripe.com/dRm14oel82sCdOud5RgIo07" class="btn btn--primary" target="_blank" rel="noopener">$50</a>
        </div>

        <p class="donate-tier-label">Front Row Jam Friend</p>
        <div class="donate-grid">
          <a href="https://buy.stripe.com/bJe3cw90O6IS7q6gi3gIo05" class="btn btn--primary" target="_blank" rel="noopener">$100</a>
        </div>

        <p class="donate-tier-label">Touring Jam Friend</p>
        <div class="donate-grid">
          <a href="https://buy.stripe.com/6oUcN6dh47MW11IaXJgIo04" class="btn btn--gold" target="_blank" rel="noopener">$250</a>
        </div>

        <p class="donate-tier-label">Jam Friend Superstar</p>
        <div class="donate-grid">
          <a href="https://buy.stripe.com/3cI28s7WKaZ87q60j5gIo06" class="btn btn--gold" target="_blank" rel="noopener">$1,000</a>
        </div>

        <div style="margin-top: 1.5rem;">
          <a href="https://donate.stripe.com/cNi8wQb8W5EOaCi8PBgIo02" class="btn btn--outline" style="color: var(--color-primary-accent); border-color: var(--color-primary-accent);" target="_blank" rel="noopener">Custom Amount</a>
        </div>
      </div>

      <p style="font-size: 0.85rem; color: var(--color-text-light); margin-top: 1.5rem;">
        You will receive an automatic email receipt for your tax records.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container text-center prose">
      <h2>What Your Donation Gets You</h2>
      <div class="tier-table">
        <div class="tier-row">
          <div class="tier-name">Jam Friend</div>
          <div class="tier-amount">$10+</div>
          <div class="tier-perks">Listed on website + sticker</div>
        </div>
        <div class="tier-row">
          <div class="tier-name">Front Row Jam Friend</div>
          <div class="tier-amount">$100+</div>
          <div class="tier-perks">Website listing + t-shirt and sticker</div>
        </div>
        <div class="tier-row">
          <div class="tier-name">Touring Jam Friend</div>
          <div class="tier-amount">$250+</div>
          <div class="tier-perks">Website listing + blanket, t-shirt, and sticker</div>
        </div>
        <div class="tier-row tier-row--highlight">
          <div class="tier-name">Jam Friend Rock Star</div>
          <div class="tier-amount">$500+</div>
          <div class="tier-perks">Website listing + blanket, t-shirt, and sticker</div>
        </div>
        <div class="tier-row tier-row--highlight">
          <div class="tier-name">Jam Friend Superstar</div>
          <div class="tier-amount">$1,000+</div>
          <div class="tier-perks">Website listing + blanket, t-shirt, and sticker</div>
        </div>
        <div class="tier-row tier-row--highlight">
          <div class="tier-name">Jam Friend Legend</div>
          <div class="tier-amount">$5,000+</div>
          <div class="tier-perks">Website listing + blanket, t-shirt, and sticker</div>
        </div>
      </div>
      <p style="font-size: 0.85rem; color: var(--color-text-light); margin-top: 1rem;">
        Present your donation receipt at any summer show to collect your merch.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container text-center prose">
      <h2>Other Ways to Donate</h2>

      <h3>Venmo</h3>
      <p>
        Send a donation via <strong>Venmo (@GeneseoJamFund)</strong>.
      </p>

      <h3>Check</h3>
      <p>
        Checks can be made payable to <strong>Geneseo Jam Fund Inc</strong> and mailed to:
      </p>
      <p>
        <strong>Geneseo Jam Fund Inc</strong><br />
        6 Oak St<br />
        Geneseo, NY 14454
      </p>

      <h3>Appreciated Securities</h3>
      <p>
        We can even accept donations of appreciated securities &mdash; if this option interests you,
        reach out to <a href="mailto:mooney@geneseojamfund.org">mooney@geneseojamfund.org</a>.
      </p>

      <h2 style="margin-top: 2.5rem;">Tax Deductibility</h2>
      <p>
        The Geneseo Jam Fund is a 501(c)(3) tax-exempt organization (EIN: 93-3285598).
        No goods or services are provided in exchange for your contribution. All donations
        are tax-deductible to the full extent of the law.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .donate-tiers {
    max-width: 480px;
    margin: 0 auto;
  }

  .donate-tier-label {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-gold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .tier-table {
    max-width: 600px;
    margin: 1.5rem auto 0;
    text-align: left;
  }

  .tier-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1rem;
    align-items: center;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-cream-dark);
  }

  .tier-row:last-child {
    border-bottom: none;
  }

  .tier-row--highlight {
    background-color: rgba(196, 162, 78, 0.08);
  }

  .tier-name {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-primary-dark);
    font-size: 0.95rem;
  }

  .tier-amount {
    font-weight: 700;
    color: var(--color-gold);
    font-size: 0.95rem;
    text-align: center;
  }

  .tier-perks {
    color: var(--color-text-light);
    font-size: 0.9rem;
    text-align: right;
  }

  @media (max-width: 768px) {
    .tier-row {
      grid-template-columns: 1fr;
      gap: 0.15rem;
      text-align: center;
      padding: 0.75rem 0.5rem;
    }

    .tier-perks {
      text-align: center;
    }

    .tier-amount {
      text-align: center;
    }
  }
</style>
