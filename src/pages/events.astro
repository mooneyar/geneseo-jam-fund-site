---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Events" description="Community music events sponsored and organized by the Geneseo Jam Fund.">
  <div class="page-header">
    <div class="container">
      <h1>Events</h1>
      <p>Music happenings in the Geneseo community</p>
    </div>
  </div>

  <section class="section">
    <div class="container prose">
      <p>
        Beyond the Sunset Concert Series and Tiny Gallery Concerts, the Geneseo Jam Fund
        sponsors and supports a variety of music events throughout the year. From benefit
        shows to festival appearances, we're always looking for ways to bring more live
        music to our community.
      </p>

      <h2>Upcoming Events</h2>
      <p style="color: var(--color-text-light);">
        No upcoming events at this time. Check back soon or follow us on social media
        for announcements.
      </p>

      <h2>Partner With Us</h2>
      <p>
        Looking to bring live music to your event, venue, or organization?
        The Geneseo Jam Fund can help with booking, promotion, and sound support.
        <a href={`${base}contact`}>Contact us</a> to discuss a partnership.
      </p>

      <h2>Past Highlights</h2>
      <p>
        The Geneseo Jam Fund has supported live music events across Livingston County,
        helping to create memorable experiences for audiences and fair opportunities
        for musicians.
      </p>
    </div>
  </section>
</BaseLayout>
