---
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';
import yaml from 'js-yaml';
import fs from 'node:fs';
import path from 'node:path';

// Load the current year's concerts
const concertPath = path.join(process.cwd(), 'src/data/concerts/2025.yaml');
let concerts: any = { shows: [], year: 2025, dates_description: 'Summer 2025' };
try {
  concerts = yaml.load(fs.readFileSync(concertPath, 'utf8'));
} catch {}

const upcomingShows = concerts.shows
  .filter((s: any) => new Date(s.date + 'T23:59:59') >= new Date())
  .slice(0, 3);

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Home">
  <!-- Hero: Drone photo as full-width opener -->
  <section class="home-hero">
    <div class="home-hero__image">
      <img
        src={`${base}images/homestead-aerial.jpg`}
        alt="Aerial view of the Geneseo Jam Kitchen Homestead during a Sunset Concert Series event"
      />
    </div>
    <div class="home-hero__overlay">
      <img src={`${base}images/logo.svg`} alt="Geneseo Jam Fund" class="home-hero__logo" />
      <h1>Geneseo Jam Fund</h1>
      <p>
        A 501(c)(3) non-profit bringing live music
        to Geneseo, NY
      </p>
      <div class="home-hero__buttons">
        <a href={`${base}donate`} class="btn btn--primary">Donate</a>
        <a href={`${base}sunset-concert-series`} class="btn btn--outline">Sunset Concert Series</a>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="section">
    <div class="container text-center">
      <h2>Our Mission</h2>
      <p style="max-width: 720px; margin: 0 auto 1rem; font-size: 1.15rem; color: var(--color-text-light);">
        Geneseo Jam Fund, a 501(c)(3) registered non-profit, aims to promote a live music culture in Geneseo, NY, that embraces musical diversity, community involvement, and artistic exploration by presenting high-quality musical performances that are inclusive, affordable, and accessible to the public.
      </p>
      <p style="max-width: 720px; margin: 0 auto; font-size: 1.15rem; color: var(--color-text-light);">
        We seek support for our activities through local, state, and national public grants allocated to supporting music and the arts; donations from engaged and generous individuals in our community; and donations from corporations with a local presence.
      </p>
    </div>
  </section>

  <!-- Upcoming Events -->
  {upcomingShows.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <h2 class="text-center">Next Up: {concerts.dates_description}</h2>
        <p class="text-center mb-3" style="color: var(--color-text-light);">
          {concerts.series} at {concerts.venue}
        </p>
        <div class="event-grid">
          {upcomingShows.map((show: any) => (
            <EventCard
              date={show.date}
              performer={show.performer}
              genre={show.genre}
              time={show.time}
              description={show.description}
            />
          ))}
        </div>
        <div class="text-center mt-4">
          <a href={`${base}sunset-concert-series`} class="btn btn--gold">View Full Lineup</a>
        </div>
      </div>
    </section>
  )}

  <!-- 2026 Fundraising CTA -->
  <section class="section section--alt">
    <div class="container text-center">
      <h2>Support the 2026 Sunset Concert Series</h2>
      <p style="max-width: 620px; margin: 0 auto 0.75rem; color: var(--color-text-light);">
        We're raising money now for the 2026 Sunset Concert Series at the Wadsworth Homestead.
        We'll be sharing more about our lineup later this spring.
      </p>
      <p style="max-width: 620px; margin: 0 auto 1.5rem; font-size: 0.95rem; color: var(--color-text-light);">
        <strong>2026 dates:</strong> May 28, June 4, June 18, July 9, July 23, August 6, and August 20
      </p>
      <div class="donate-grid" style="max-width: 420px; margin: 0 auto;">
        <a href="https://donate.stripe.com/9B6aEY1ym1oyaCifdZgIo03" class="btn btn--primary btn--small" target="_blank" rel="noopener">$10</a>
        <a href="https://donate.stripe.com/9B628s7WK4AK11I7LxgIo01" class="btn btn--primary btn--small" target="_blank" rel="noopener">$25</a>
        <a href="https://donate.stripe.com/dRm14oel82sCdOud5RgIo07" class="btn btn--primary btn--small" target="_blank" rel="noopener">$50</a>
        <a href="https://donate.stripe.com/bJe3cw90O6IS7q6gi3gIo05" class="btn btn--primary btn--small" target="_blank" rel="noopener">$100</a>
        <a href="https://donate.stripe.com/6oUcN6dh47MW11IaXJgIo04" class="btn btn--gold btn--small" target="_blank" rel="noopener">$250</a>
        <a href="https://donate.stripe.com/3cI28s7WKaZ87q60j5gIo06" class="btn btn--gold btn--small" target="_blank" rel="noopener">$1,000</a>
        <a href="https://donate.stripe.com/cNi8wQb8W5EOaCi8PBgIo02" class="btn btn--outline btn--small" style="color: var(--color-primary-accent); border-color: var(--color-primary-accent);" target="_blank" rel="noopener">Other</a>
      </div>
      <p style="font-size: 0.85rem; color: var(--color-text-light); margin-top: 1rem;">
        All donations are tax-deductible. <a href={`${base}donate`}>More ways to donate &rarr;</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .home-hero__image img {
    width: 100%;
    display: block;
    max-height: 85vh;
    object-fit: cover;
  }

  .home-hero__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem 1.5rem;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.1) 0%,
      rgba(0, 0, 0, 0.35) 50%,
      rgba(0, 0, 0, 0.55) 100%
    );
  }

  .home-hero__logo {
    width: 150px;
    height: 150px;
    margin-bottom: 1.25rem;
    filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.4));
  }

  .home-hero__overlay h1 {
    color: white;
    font-size: 3.2rem;
    margin-bottom: 0.5rem;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.5);
  }

  .home-hero__overlay p {
    color: white;
    font-size: 1.3rem;
    margin-bottom: 2rem;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.5);
  }

  .home-hero__buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .home-hero {
      min-height: 70vh;
    }

    .home-hero__image {
      position: absolute;
      inset: 0;
    }

    .home-hero__image img {
      height: 100%;
      max-height: none;
    }

    .home-hero__logo {
      width: 110px;
      height: 110px;
    }

    .home-hero__overlay h1 {
      font-size: 2.2rem;
    }

    .home-hero__overlay p {
      font-size: 1.1rem;
    }
  }
</style>
