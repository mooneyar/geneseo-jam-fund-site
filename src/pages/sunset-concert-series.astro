---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

// Sponsor logo mappings: filename -> display name
const base = import.meta.env.BASE_URL;

const sponsorLogoMap: Record<string, string> = {
  'aes_logo.png': 'AES',
  'BARILLALOGO2021.png': 'Barilla',
  'CCOR_logo.png': 'CCOR',
  'gvca_logo.png': 'Genesee Valley Council on the Arts',
  'lakehour_logo.png': 'Lake Hour',
  'nut_butter.jpg': 'Once Again Nut Butter',
  'p_and_cg.ai.jpg': 'Power and Construction Group',
  'racf_logo.jpg': 'Rochester Area Community Foundation',
  'tompkins_logo.png': 'Tompkins Bank',
  'wegmans.png': 'Wegmans',
  'The Chosen Pot Sign.JPG': 'The Chosen Pot',
  'cottones_logo.png': 'Cottone Auctions',
  'Coast50_hor_gold_CAREERS_CMYK.png': 'Coast Professional',
  'ENCOMPASS PIPELINE STD PNG(White).png': 'Encompass Pipeline',
  'rohrbach_logo.jpg': 'Rohrbach Brewing Company',
};

const sponsorUrlMap: Record<string, string> = {
  'BARILLALOGO2021.png': 'https://www.barillagroup.com/en/careers/',
  'aes_logo.png': 'https://www.aes.com/',
  'gvca_logo.png': 'https://gvartscouncil.org/',
  'p_and_cg.ai.jpg': 'https://www.pandcg.com/',
  'wegmans.png': 'https://jobs.wegmans.com/en',
  'The Chosen Pot Sign.JPG': 'https://www.instagram.com/popular/the-chosen-pot-dispensary-lima-ny/',
  'cottones_logo.png': 'https://www.cottoneauctions.com/',
  'Coast50_hor_gold_CAREERS_CMYK.png': 'https://www.coastprofessional.com/careers',
  'ENCOMPASS PIPELINE STD PNG(White).png': 'https://www.encompasspipelinellc.com/',
  'rohrbach_logo.jpg': 'https://www.rohrbachs.com/',
};

const sponsorLogosDir = path.join(process.cwd(), 'public/images/sponsors');
let sponsorLogos: string[] = [];
try {
  const only2026 = new Set(['The Chosen Pot Sign.JPG', 'cottones_logo.png', 'Coast50_hor_gold_CAREERS_CMYK.png', 'ENCOMPASS PIPELINE STD PNG(White).png', 'rohrbach_logo.jpg']);
  sponsorLogos = fs.readdirSync(sponsorLogosDir)
    .filter(f => /\.(png|jpg|jpeg|svg|webp)$/i.test(f) && !only2026.has(f))
    .sort();
} catch {}

// Sponsor tiers with names
const sponsorTiers = [
  {
    tier: 'Legends',
    names: ['Genesee Valley Council on the Arts', 'Barilla'],
  },
  {
    tier: 'Superstars',
    names: [
      'Rochester Area Community Foundation',
      'Tompkins Bank',
      'Lake Hour',
      'Once Again Nut Butter',
      'AES',
      'Power and Construction Group',
      'John Lockhart and Lynne Mazadoorian',
      'Dominick Ens',
      'Jeremy and Anna Grace',
      'Andrew Mooney and Catherine Lloyd',
      'Will and Louise Wadsworth',
      'Eden Dedrick',
    ],
  },
  {
    tier: 'Rock Stars',
    names: ['Wegmans', 'Sure Can House of Creative'],
  },
  {
    tier: 'Touring',
    names: [
      'Martin and Theresa Miskell',
      'Ankur Patel',
      'Liam and Jonah Grosse',
      'Joanna and Keith Walters',
      'Paige Thompson',
      'James Lynch',
      'Elizabeth Hobson and Richard Morris',
    ],
  },
  {
    tier: 'Front Row',
    names: [
      'Pecora and Esme Levey',
      'Erin Sweeney',
      'Mark Roberts',
      'Al and Laurie Mooney',
      'Bob Bunce',
      'Maryann Cully',
      'Kelley Tonra',
      'Robert Goeckel',
      'Lauren and Crista Wadsworth',
      'Jeffrey Marks',
      'Krysta Smith',
      'Allison and Travis Cook',
      'Grayce Mclaughlin and Fred Mingrino',
      'Paul Schill',
      'Sally Nelson',
      'The Sharman Team',
      'Jillian Baird',
      'Paul Kreher',
    ],
  },
];
---

<BaseLayout title="Sunset Concert Series" description="The Sunset Concert Series brings free live music to Geneseo, NY every summer.">
  <!-- Hero -->
  <section class="hero">
    <div class="hero__bg" style={`background-image: url('${base}images/sunset-series-header.jpg');`}></div>
    <div class="hero__content">
      <h1>Sunset Concert Series</h1>
      <p>Free live music on the Wadsworth Homestead lawn on select Thursday evenings, all summer long</p>
    </div>
  </section>

  <!-- 2026 Season -->
  <section class="section">
    <div class="container text-center">
      <h2>2026 Sunset Concert Series</h2>
      <div class="lineup-image">
        <img src={`${base}images/sunset-series-lineup-2026.jpg`} alt="2026 Sunset Concert Series Lineup" />
      </div>
      <p style="color: var(--color-text-light); max-width: 620px; margin: 0 auto 1rem;">
        Admission is free of charge thanks to the generosity of our sponsors and donors.
      </p>
      <div class="lineup-schedule">
        <div class="lineup-date">
          <span class="lineup-date__label">May 28</span>
          <span class="lineup-date__artists">The Town Pants <span class="lineup-wsg">wsg Smilo &amp; The Ghost</span></span>
        </div>
        <div class="lineup-date">
          <span class="lineup-date__label">June 4</span>
          <span class="lineup-date__artists">BeatlesRoc <span class="lineup-wsg">wsg Felicity Thomas</span></span>
        </div>
        <div class="lineup-date">
          <span class="lineup-date__label">June 18</span>
          <span class="lineup-date__artists">Dirty Blanket <span class="lineup-wsg">wsg Eastern Boys in Western Shirts</span></span>
        </div>
        <div class="lineup-date">
          <span class="lineup-date__label">July 9</span>
          <span class="lineup-date__artists">The World's Largest 80's Party feat. M80's <span class="lineup-wsg">wsg Roc Academy</span></span>
        </div>
        <div class="lineup-date">
          <span class="lineup-date__label">July 23</span>
          <span class="lineup-date__artists">Ric Robertson Band &bull; Adrianna Noone</span>
        </div>
        <div class="lineup-date">
          <span class="lineup-date__label">Aug 6</span>
          <span class="lineup-date__artists">Prime Time Funk &bull; Cinnamon Jones</span>
        </div>
        <div class="lineup-date">
          <span class="lineup-date__label">Aug 20</span>
          <span class="lineup-date__artists">Mustard Tigers &bull; Folkfaces</span>
        </div>
      </div>
      <p style="color: var(--color-text-light); max-width: 620px; margin: 0 auto 1.5rem;">
        Interested in sponsoring? Contact us at
        <a href="mailto:mooney@geneseojamfund.org">mooney@geneseojamfund.org</a>.
        Follow us on
        <a href="https://www.instagram.com/geneseojamfund/" target="_blank" rel="noopener noreferrer">Instagram</a>
        and
        <a href="https://www.facebook.com/geneseojamfund" target="_blank" rel="noopener noreferrer">Facebook</a>
        for lineup announcements!
      </p>
      <div style="margin-top: 1.5rem;">
        <a href={`${base}donate`} class="btn btn--primary">Donate Now</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container prose">
      <h2 class="text-center">Frequently Asked Questions</h2>

      <div class="faq">
        <h3>Where and when are the shows?</h3>
        <p>
          The <a href="https://www.wadsworthhomestead.com/" target="_blank" rel="noopener noreferrer">Wadsworth Homestead</a>,
          located at 4 South Street in Geneseo, hosts all performances.
          Gates open at 5:00 p.m., with opening acts typically performing 5:30&ndash;6:30 p.m.
          and headliners at 7:00 p.m.
        </p>

        <h3>Do I need tickets or reservations?</h3>
        <p>
          Thanks to our generous sponsors and donors, the series is entirely free.
          In the rare event that we have capacity limitations, reservations may be required.
          But expect that no reservations are required, unless clearly indicated with ticketing
          links on our website and social media.
        </p>

        <h3>Are food and beverages available?</h3>
        <p>
          Yes. Alcoholic and non-alcoholic drinks are sold onsite. Food vendors include
          Cosmic Charlie Cafe (burritos) and Wadsworth Grill (hamburgers/hot dogs).
          Outside food and beverages are prohibited, except water.
        </p>

        <h3>Are shows family and pet friendly?</h3>
        <p>
          We welcome music lovers of all ages, with ample open space for children to play.
          Only service animals per ADA regulations are permitted.
        </p>

        <h3>What can I bring?</h3>
        <p>
          Blankets, lawn chairs, backpacks, sunscreen, phones, unopened water bottles,
          and point-and-shoot cameras are allowed. Bottles, cans, weapons, professional
          cameras, fireworks, and coolers are prohibited.
        </p>

        <h3>What happens in the event of rain?</h3>
        <p>
          A 250-person tent accommodates attendees during rain. Advance reservations
          receive priority admission. Severe weather may result in postponement or
          cancellation.
        </p>
      </div>
    </div>
  </section>

  <!-- Wadsworth Partnership -->
  <section class="section section--alt">
    <div class="container prose" style="text-align: center;">
      <h2>Thank You to the Wadsworth Homestead</h2>
      <p>
        We are grateful to the
        <a href="https://www.wadsworthhomestead.com/" target="_blank" rel="noopener noreferrer">Wadsworth Homestead</a>,
        which generously donates their venue free of charge to host our events.
        The Wadsworth Homestead's beautiful grounds provide the perfect setting
        for an evening of live music under the open sky.
      </p>
    </div>
  </section>

  <!-- 2026 Sponsors -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">2026 Sponsors &amp; Donors</h2>
      <p class="text-center" style="color: var(--color-text-light); max-width: 520px; margin: 0 auto 1.5rem;">
        We're currently seeking sponsors for the 2026 season. Interested in supporting
        the series? <a href="mailto:mooney@geneseojamfund.org">Get in touch</a>.
      </p>

      <div class="sponsor-logos">
        <div class="sponsor-logos__grid">
          {['BARILLALOGO2021.png', 'aes_logo.png', 'gvca_logo.png', 'p_and_cg.ai.jpg', 'wegmans.png', 'The Chosen Pot Sign.JPG', 'cottones_logo.png', 'Coast50_hor_gold_CAREERS_CMYK.png', 'ENCOMPASS PIPELINE STD PNG(White).png', 'rohrbach_logo.jpg'].map(logo => (
            <div class="sponsor-logos__item">
              <a href={sponsorUrlMap[logo]} target="_blank" rel="noopener noreferrer">
                <img src={`${base}images/sponsors/${logo}`} alt={sponsorLogoMap[logo] || logo} />
              </a>
            </div>
          ))}
        </div>
      </div>

      <div class="sponsor-tier">
        <h3>Legends</h3>
        <p>Barilla &bull; Coast Professional &bull; Genesee Valley Council on the Arts &bull; Sally Wood</p>
      </div>
      <div class="sponsor-tier">
        <h3>Superstars</h3>
        <p>AES &bull; Chosen Pot Dispensary &bull; Cottone Auctions &bull; Dominick &amp; Elizabeth Ens &bull; Encompass Pipeline &bull; Jim Lynch &bull; Lynne Mazadoorian &amp; John Lockhart &bull; Meg &amp; Billy Lloyd &bull; Power and Construction Group &bull; Rohrbach Brewing Company &bull; The Templeton Fund</p>
      </div>
      <div class="sponsor-tier">
        <h3>Rock Stars</h3>
        <p>Joe Schill &bull; Wegmans</p>
      </div>
      <div class="sponsor-tier">
        <h3>Touring</h3>
        <p>Elizabeth Hobson &amp; Rick Morris</p>
      </div>
      <div class="sponsor-tier">
        <h3>Front Row</h3>
        <p>Jodi Beyer &bull; Bob Bunce &bull; Linda Gibbs &bull; Christopher Giovanni &bull; Lisa Hobson &bull; Paul Kreher &bull; William Krone &bull; Dave Lagoner &bull; Pecora &amp; Esme Levey &bull; Coyne Lloyd &bull; Al &amp; Laurie Mooney &bull; Sally Nelson &bull; Lesa Sobolewski &bull; Anne Stevens &bull; Katherine Wood</p>
      </div>
      <div class="sponsor-tier">
        <h3>Jam Friend</h3>
        <p>Josh Boss &bull; Susan Dimpfl &bull; Liana Grosse &bull; Ryan Grosse &bull; Graham Lloyd &bull; Lori Mann &bull; Claire Mulligan &bull; Jared Radesi &bull; Paul Schill &bull; Chic Yoder</p>
      </div>

      <p class="text-center" style="font-size: 0.85rem; color: var(--color-text-light); max-width: 580px; margin: 2rem auto 0; font-style: italic;">
        This project is made possible with funds from the Statewide Community Regrants Program,
        a regrant program of the New York State Council on the Arts with the support of The Office
        of the Governor and the New York State Legislature and administered by the Genesee Valley
        Council on the Arts.
      </p>
    </div>
  </section>

  <!-- Past Sponsors -->
  <section class="section section--alt">
    <div class="container">
      <h2 class="text-center">Past Sponsors &amp; Donors</h2>
      <p class="text-center" style="color: var(--color-text-light); margin-bottom: 2rem;">
        Thank you to everyone who supported the 2025 Sunset Concert Series.
      </p>

      {sponsorLogos.length > 0 && (
        <div class="sponsor-logos">
          <h3 class="text-center">Corporate Sponsors</h3>
          <div class="sponsor-logos__grid">
            {sponsorLogos.map(logo => (
              <div class="sponsor-logos__item">
                <a href={sponsorUrlMap[logo]} target="_blank" rel="noopener noreferrer">
                  <img src={`${base}images/sponsors/${logo}`} alt={sponsorLogoMap[logo] || logo.replace(/\.[^.]+$/, '').replace(/[-_]/g, ' ')} />
                </a>
              </div>
            ))}
          </div>
        </div>
      )}

      {sponsorTiers.map(tier => (
        <div class="sponsor-tier">
          <h3>{tier.tier}</h3>
          <p>{tier.names.join(' \u2022 ')}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .lineup-image {
    max-width: 500px;
    margin: 0 auto 2.5rem;
  }

  .lineup-image img {
    width: 100%;
    border-radius: 10px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  }

  .lineup-schedule {
    max-width: 560px;
    margin: 0 auto 1.5rem;
    text-align: left;
  }

  .lineup-date {
    display: flex;
    gap: 1rem;
    align-items: baseline;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-cream-dark);
  }

  .lineup-date:last-child {
    border-bottom: none;
  }

  .lineup-date__label {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-gold);
    min-width: 70px;
    font-size: 0.95rem;
  }

  .lineup-date__artists {
    color: var(--color-primary-dark);
    font-weight: 600;
    font-size: 1rem;
  }

  .lineup-wsg {
    font-weight: 400;
    color: var(--color-text-light);
    font-size: 0.9rem;
  }

  @media (max-width: 480px) {
    .lineup-date {
      flex-direction: column;
      gap: 0.15rem;
    }
  }

  .sponsor-logos {
    margin-bottom: 2.5rem;
  }

  .sponsor-logos__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    margin-top: 1rem;
  }

  .sponsor-logos__item img {
    max-height: 80px;
    max-width: 180px;
    object-fit: contain;
  }

  .sponsor-tier {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .sponsor-tier h3 {
    margin-bottom: 0.5rem;
    color: var(--color-sage);
  }

  .sponsor-tier p {
    color: var(--color-text-light);
    font-size: 1rem;
    line-height: 1.6;
  }

  .faq {
    max-width: 700px;
    margin: 0 auto;
  }

  .faq h3 {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .faq h3:first-child {
    margin-top: 0;
  }

  .faq p {
    color: var(--color-text-light);
  }
</style>
